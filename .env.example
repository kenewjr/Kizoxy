# ════════════════════════════════════════════════════════
#  Bot Configuration
# ════════════════════════════════════════════════════════
TOKEN=insertyourtokenhere
EMBED_COLOR=#000001
PREFIX=k
OWNER_ID=
SEARCH_ENGINE=youtube
LEAVE_EMPTY=120000

# ════════════════════════════════════════════════════════
#  Lavalink Node Connection
# ════════════════════════════════════════════════════════
NODE_NAME=NanoSpace
NODE_URL=localhost:5555
NODE_AUTH=nanospace
LAVALINK_URL=http://localhost:2333
LAVALINK_PASSWORD=youshallnotpass

# ════════════════════════════════════════════════════════
#  Integration Keys
# ════════════════════════════════════════════════════════
# YouTube Data API v3 key. Optional: disables YouTube notifier if empty.
YOUTUBE_API_KEY=
# Configurable TikTok data provider base url and API key
TIKTOK_API_BASE=
TIKTOK_API_KEY=

# ════════════════════════════════════════════════════════
#  Logging & Reporter Options
# ════════════════════════════════════════════════════════
# LOG_FORMAT: "pretty" (terminal) or "json" (production)
LOG_FORMAT=pretty
# LOG_TO_FILE: set to false to disable disk logs
LOG_TO_FILE=true
# Discord webhook URL for automated error reports
ERROR_WEBHOOK_URL=

# ════════════════════════════════════════════════════════
#  Local Dashboard Configuration
# ════════════════════════════════════════════════════════
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=4040
BOT_COLOR=#5865F2