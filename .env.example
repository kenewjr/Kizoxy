# ════════════════════════════════════════════════════════
#  Bot Configuration
# ════════════════════════════════════════════════════════
TOKEN=inseryourtokenhere
EMBED_COLOR=#000001
PREFIX=k

SEARCH_ENGINE=youtube

LEAVE_EMPTY=120000

# ════════════════════════════════════════════════════════
#  Developer
# ════════════════════════════════════════════════════════
OWNER_ID=

# ════════════════════════════════════════════════════════
#  Lavalink Node
# ════════════════════════════════════════════════════════
NODE_NAME=insertyournodehere
NODE_URL=0.0.0.0:2333
NODE_AUTH=youshallnotpass
# Used by lyricsService for direct Lavalink lyrics fetch
LAVALINK_URL=http://0.0.0.0:2333
LAVALINK_PASSWORD=youshallnotpass

# ════════════════════════════════════════════════════════
#  Spotify (NOT used by this bot anymore)
# ════════════════════════════════════════════════════════
# Spotify resolution is handled by LavaSrc plugin on the Lavalink side.
# Configure clientId/clientSecret inside LavalinkServer/application.yml
# under plugins.lavasrc.spotify, NOT here.
# These variables are kept for backwards compatibility only and are
# safely ignored by the current bot code.
# spotifyClientID=
# spotifySecret=

# ════════════════════════════════════════════════════════
#  Logging
# ════════════════════════════════════════════════════════
# "pretty" = colored terminal output (dev)
# "json"   = structured JSON output (production / PM2)
LOG_FORMAT=pretty

# Discord webhook URL for error notifications
ERROR_WEBHOOK_URL=
