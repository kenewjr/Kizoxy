{
  "dependencies": {
    "canvacord": "^6.0.4",
    "discord.js": "^14.27.0",
    "dotenv": "^17.4.2",
    "express": "^5.1.0",
    "fast-xml-parser": "^5.10.1",
    "kazagumo": "^3.4.3",
    "kuroshiro": "^1.2.0",
    "kuroshiro-analyzer-kuromoji": "^1.1.0",
    "node-cache": "^5.1.2",
    "sharp": "^0.35.3",
    "shoukaku": "^4.3.0",
    "uuid": "^14.0.1"
  },
  "name": "kizoxy",
  "description": "Kizoxy is a premium multipurpose Discord bot.",
  "version": "3.6",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "start:pm2": "pm2 start ecosystem.config.js",
    "stop:pm2": "pm2 stop kizoxy",
    "restart:pm2": "pm2 restart kizoxy",
    "logs:pm2": "pm2 logs kizoxy",
    "deploy:slash": "node scripts/deploySlash.js",
    "deploy:slash:global": "node scripts/deploySlash.js global --clear-all",
    "deploy:slash:guild": "node scripts/deploySlash.js guild",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "test": "jest tests/",
    "test:coverage": "jest --coverage",
    "validate:modules": "node scripts/validateModules.js",
    "validate:env": "node scripts/validateEnv.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kenewjr/Kizoxy.git"
  },
  "bugs": {
    "url": "https://github.com/kenewjr/Kizoxy/issues"
  },
  "homepage": "https://github.com/kenewjr/Kizoxy",
  "author": "Kenewjr",
  "license": "Apache-2.0",
  "devDependencies": {
    "eslint": "^10.7.0",
    "jest": "^30.4.2",
    "prettier": "^3.9.6",
    "supertest": "^7.2.2"
  },
  "jest": {
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "testTimeout": 15000,
    "clearMocks": true,
    "restoreMocks": false,
    "setupFilesAfterEnv": [
      "<rootDir>/tests/setupAfterEnv.js"
    ],
    "coverageThreshold": {
      "global": {
        "statements": 70,
        "branches": 55,
        "functions": 65,
        "lines": 70
      },
      "./src/lib/interactions.js": {
        "statements": 85
      },
      "./src/lib/embeds.js": {
        "statements": 90
      },
      "./src/persistence/jsonStorage.js": {
        "statements": 85
      },
      "./src/persistence/levelStorage.js": {
        "statements": 85
      },
      "./src/features/music/musicHelper.js": {
        "statements": 80
      },
      "./src/events/client/clientReady.js": {
        "statements": 75
      }
    }
  }
}
